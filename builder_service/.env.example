# Builder Service Configuration
# Copy this to .env and fill in your values

# ─── LLM Provider ─────────────────────────────────────────
# Options: azure, openai, anthropic
LLM_PROVIDER=azure

# ─── Azure OpenAI ─────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_MINI_DEPLOYMENT=gpt-4o-mini

# ─── Direct OpenAI (if LLM_PROVIDER=openai) ──────────────
# OPENAI_API_KEY=sk-your-key
# OPENAI_MODEL=gpt-4o
# OPENAI_MINI_MODEL=gpt-4o-mini

# ─── Anthropic (if LLM_PROVIDER=anthropic) ────────────────
# ANTHROPIC_API_KEY=your-key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── AI Hub Connection ────────────────────────────────────
AI_HUB_BASE_URL=http://localhost:5000
AI_HUB_API_KEY=

# ─── Service ──────────────────────────────────────────────
BUILDER_HOST=0.0.0.0
BUILDER_PORT=8100
BUILDER_DEBUG=true
