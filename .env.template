# =============================================================================
# AI Hub Configuration
# Copy this file to .env and fill in your values
# =============================================================================

#########################
# SYSTEM PARAMS
#########################
HOST=0.0.0.0
HOST_DEBUG=false
HOST_PORT=5001
SERVER_THREADS=16
VECTOR_SERVER_THREADS=4
KNOWLEDGE_SERVER_THREADS=4
EXECUTOR_SERVICE_THREADS=4
SERVER_CONNECTION_LIMIT=1000
BYPASS_PROXY=false
USE_REVERSE_PROXY=false

# Application root directory (absolute path)
APP_ROOT=C:\path\to\aihub

# Tenant API Key (your unique tenant identifier)
API_KEY=your-tenant-api-key

#########################
# ENCRYPTION
#########################
# Used to encrypt/decrypt API keys stored in this file
# Generate your own random strings for production
ENCRYPTION_SECRET=your-encryption-secret
ENCRYPTION_SALT=your-encryption-salt

# Flask session secret key
FLASK_SECRET_KEY=generate-a-random-secret-here

#########################
# DATABASE
#########################
DATABASE_SERVER=localhost
DATABASE_NAME=AIHUB
DATABASE_UID=your_db_user
DATABASE_PWD=your_db_password
DATABASE_DRIVER=ODBC+Driver+17+for+SQL+Server

# Cloud Database (optional, defaults to primary database values)
# CLOUD_DATABASE_SERVER=
# CLOUD_DATABASE_NAME=
# CLOUD_DATABASE_UID=
# CLOUD_DATABASE_PWD=

#########################
# LLM PROVIDERS
#########################
# Azure OpenAI (primary)
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY_ENCRYPTED=your-encrypted-key
# Or provide plaintext key directly:
# AZURE_OPENAI_API_KEY=your-api-key

# Azure OpenAI (alternate, optional - defaults to primary)
# AZURE_OPENAI_BASE_URL_ALTERNATE=
# AZURE_OPENAI_API_KEY_ALTERNATE_ENCRYPTED=

# Azure OpenAI (mini model, optional - defaults to primary)
# AZURE_OPENAI_BASE_URL_MINI=
# AZURE_OPENAI_API_KEY_ENCRYPTED_MINI=

# OpenAI Direct (optional)
# OPENAI_API_KEY_ENCRYPTED=your-encrypted-key
# OPENAI_API_KEY=your-api-key

# Anthropic
# ANTHROPIC_API_KEY_ENCRYPTED=your-encrypted-key
# ANTHROPIC_API_KEY=your-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=64000
ANTHROPIC_API_THROTTLE_CALLS=false
ANTHROPIC_API_THROTTLE_DELAY=1

# NLQ Provider: "openai" or "anthropic"
# NLQ_PROVIDER=anthropic

#########################
# LLM PARAMETERS
#########################
LLM_ROW_LIMIT=50
LLM_CHARACTER_LIMIT=8000
LLM_TEMPERATURE=0.0
LLM_SEED=99
LLM_PANDAS_AGENT_DESCRIPTION=You are a data analysis agent. Your main goal is to help non-technical users to analyze data.
LLM_PANDAS_CODE_REGEN_SYSTEM=Your objective is to analyze a users question, the SQL that was generated to answer the question, and create python code using the provided dataframe.
LLM_PANDAS_CODE_REGEN_PROMPT=User Question: {question}\\n\\nSQL Query: {query}\\n\\nDataframe: {dataframe}\\n\\nCode: \\n

#########################
# LOGGING
#########################
LOG_LEVEL=DEBUG
LOG_DIR=./logs/app_log.txt
LOG_DIR_DATA=./logs/data_log.txt
LOG_DIR_AGENT=./logs/agent_log.txt
LLM_ENGINE_LOG=./logs/data_engine_log.txt
LLM_QUERY_LOG=./logs/query_engine_log.txt
DOC_JOB_QUEUE_LOG=./logs/document_job_queue_processor.txt
DOC_API_LOG=./logs/doc_api_log.txt
JOB_SCHEDULER_LOG=./logs/job_scheduler_log.txt
JOB_SCHEDULER_SERVICE_LOG=./logs/job_scheduler_service_log.txt
DOC_VECTOR_API_LOG=./logs/doc_vector_api_log.txt
SMART_CONTENT_RENDER_LOG=./logs/smart_content_render_log.txt

#########################
# EMAIL
#########################
# Provider: "azure" or "smtp"
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Azure Communication Services (if EMAIL_PROVIDER=azure)
# API_AZURE_COMM_CONN_STR=endpoint=https://...;accesskey=...
# API_AZURE_EMAIL_CONN_STR=endpoint=https://...;accesskey=...
# API_AZURE_EMAIL_SENDER=donotreply@yourdomain.com

#########################
# PHONE / SMS (optional)
#########################
# PHONE_BASE_URL=
# PHONE_SOURCE=+1XXXXXXXXXX
# PHONE_DISPLAY_NAME=AI Hub

#########################
# WEB SEARCH (optional)
#########################
# TAVILY_API_KEY_ENCRYPTED=your-encrypted-key
# TAVILY_API_KEY=your-tavily-key

#########################
# AI HUB CLOUD PROXY
#########################
AI_HUB_API_URL=https://ai-hub-api.azurewebsites.net/
AI_HUB_PROXY_OPENAI=openai_proxy_request_v3/
AI_HUB_PROMPT_MINI=quick_prompt_mini_request_v2/
AI_HUB_DOCUMENT_API_URL=https://ai-hub-api.azurewebsites.net/
AI_HUB_DOCUMENT_PROCESS_ROUTE=api/proxy/process/documents/v2
AI_HUB_PROXY_ANTHROPIC_MESSAGES=api/proxy/anthropic/messages/v2
AI_HUB_PROXY_ANTHROPIC_STREAM=api/proxy/anthropic/messages/stream/v2

#########################
# WINDOWS AUTOMATION (optional)
#########################
# WINTASK_USER=
# WINTASK_PWD=
# WINTASK_FOLDER=\\AI
# WINRM_USER=
# WINRM_PWD=
# WINRM_DOMAIN=

#########################
# MISC
#########################
CUSTOM_TOOLS_FOLDER=tools
QUICK_JOB_EXECUTION_SCRIPT=ExecuteQuickJob.exe
WORKFLOW_TRAINING_CAPTURE_ENABLED=true
WORKFLOW_TRAINING_CAPTURE_PATH=./training_data/workflows
USE_TWO_STAGE_ARCHITECTURE=true
USE_WORKFLOW_EXECUTOR_SERVICE=true
TEXT_FILE_EXTENSIONS=.txt,.md,.html,.css,.js,.json,.xml,.yaml,.yml,.csv,.tsv,.log,.py,.sql
