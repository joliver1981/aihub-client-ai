# PredictiveForecast Configuration
# Copy this file to .env and adjust values as needed.

# Server
FC_HOST=0.0.0.0
FC_PORT=5005
FC_THREADS=4
FC_DEBUG=false
FC_SECRET_KEY=change-this-in-production

# Upload limits (MB)
FC_MAX_UPLOAD_MB=500

# Neural Network Defaults
FC_DNN_EPOCHS=100
FC_DNN_BATCH_SIZE=32
FC_DNN_DROPOUT=0.2
FC_DNN_LAYER_1=128
FC_DNN_LAYER_2=64
FC_DNN_PATIENCE=10
FC_DNN_USE_KFOLD=true
FC_DNN_NUM_FOLDS=5

# Feature Analysis
FC_CUMULATIVE_IMPORTANCE=0.99
FC_FEATURE_IMPORTANCE_ITER=10

# Confidence
FC_MC_DROPOUT_ITER=100
FC_CONFIDENCE_LEVEL=0.80
